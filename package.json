{
  "name": "uaw",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tauri": "tauri",
    "e2e": "wdio run wdio.conf.ts",
    "e2e:build": "tauri build --debug --no-bundle",
    "e2e:typecheck": "tsc -p tsconfig.e2e.json",
    "e2e:docker": "docker build -f Dockerfile.e2e -t uaw-e2e . && docker run --rm uaw-e2e",
    "sidecar:install": "npm ci --ignore-scripts --omit=optional --prefix sidecar/claude-agent-sdk",
    "bundle": "pnpm sidecar:install && pnpm tauri build"
  },
  "dependencies": {
    "@relements/core": "^1.0.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.11",
    "markdown-it": "^14.2.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@wdio/cli": "^9.28.0",
    "@wdio/globals": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "@wdio/types": "^9.28.0",
    "expect-webdriverio": "^5.6.8",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "webdriverio": "^9.28.0"
  }
}
